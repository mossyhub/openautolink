# wpa_supplicant build-time config for CPC200
#
# Minimal feature set: WPA2-PSK and WPA3-SAE for home/car WiFi.
# Static linkage requested via LDFLAGS in build-wpa.sh.
# No EAP (no enterprise) — keeps binary small and avoids OpenSSL dep.

# Driver: nl80211 only (the CPC200's mlan driver speaks cfg80211)
CONFIG_DRIVER_NL80211=y
CONFIG_LIBNL32=y

# Control interface — wpa_cli needs this
CONFIG_CTRL_IFACE=y
CONFIG_CTRL_IFACE_UNIX=y

# WPA2-PSK (covers all home/car/phone hotspots)
CONFIG_WPA=y
CONFIG_NO_WPA_PASSPHRASE=

# WPA3-SAE intentionally disabled — needs CONFIG_ECC + EC bignum support which
# bloats the binary considerably and isn't needed for any real-world AP we'll
# encounter. Re-enable + add CONFIG_ECC=y if a WPA3-only network ever blocks us.
#CONFIG_SAE=y

# Internal crypto (avoids OpenSSL dep — fine for PSK)
CONFIG_TLS=internal
CONFIG_INTERNAL_LIBTOMMATH=y

# Background scan + roaming
CONFIG_BGSCAN_SIMPLE=y

# Strip features we don't need to keep the binary tiny
CONFIG_NO_RANDOM_POOL=y
CONFIG_NO_STDOUT_DEBUG=
CONFIG_NO_CONFIG_BLOBS=y
CONFIG_NO_SCAN_PROCESSING=
CONFIG_NO_ROAMING=

# No EAP (no enterprise WiFi support — keep it minimal)
# (leaving all CONFIG_EAP_* commented out)

# No mesh, no P2P, no Wi-Fi Direct
# (defaults are off)

# No IEEE 802.11r FT (fast transition between APs)
CONFIG_IEEE80211R=

# Compile flags injected by build-wpa.sh via env
